# To connect to your host database, use something like DATABASE_URL=postgres://copelco@host.docker.internal:5432/ncpollbook
DATABASE_URL=postgres://postgres@db:5432/ncpollbook
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_MANAGEPY_MIGRATE=on

